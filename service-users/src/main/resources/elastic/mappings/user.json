{
  "dynamic": "strict",
  "properties": {
    "id": {
      "type": "keyword"
    },
    "created": {
      "type": "date"
    },
    "username": {
      "type": "text",
      "analyzer": "autocomplete_tr",
      "search_analyzer": "autocomplete_tr_search",
      "fields": {
        "keyword": {
          "type": "keyword",
          "ignore_above": 256
        }
      }
    },
    "enabled": {
      "type": "boolean"
    },
    "verified": {
      "type": "boolean"
    }
  }
}